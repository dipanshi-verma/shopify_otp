# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Your Railway/Render/ngrok public domain (NO https://, just the domain)
# Example: shopify-otp-idp.up.railway.app
NGROK_HOST=YOUR_DEPLOYED_DOMAIN_HERE

# ─── Shopify ──────────────────────────────────────────────────────────────────
# Found in Shopify Admin → Settings → General → Store ID (the number)
SHOP_ID=YOUR_SHOPIFY_STORE_ID

# Your myshopify subdomain (without .myshopify.com)
# Example: dipanshi-dynamic-dreamz
SHOP_DOMAIN=dipanshi-dynamic-dreamz

# From Shopify Admin → Settings → Customer Accounts → Authentication → Manage
# (After you register the IDP, Shopify gives you these)
CLIENT_ID=YOUR_SHOPIFY_CLIENT_ID
CLIENT_SECRET=YOUR_SHOPIFY_CLIENT_SECRET

# ─── MSG91 ────────────────────────────────────────────────────────────────────
# From MSG91 Dashboard → Profile → API Keys
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY

# From MSG91 → OTP Widget → Widget Settings → Widget ID
MSG91_WIDGET_ID=YOUR_WIDGET_ID

# From MSG91 → SendOTP → Templates → your SMS template ID
MSG91_TEMPLATE_ID=YOUR_TEMPLATE_ID

# ─── Security ─────────────────────────────────────────────────────────────────
# Any long random string — used to sign session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=YOUR_RANDOM_COOKIE_SECRET_HERE
