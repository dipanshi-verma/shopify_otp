# ─── Ngrok ───────────────────────────────────────────────────────────────────
# Your ngrok hostname WITHOUT https:// (e.g. salamanderlike-uppishly-hosea.ngrok-free.dev)
NGROK_HOST=your-ngrok-subdomain.ngrok-free.dev

# ─── Shopify ──────────────────────────────────────────────────────────────────
# From Shopify Admin → Settings → Customer Accounts → Identity Provider
CLIENT_ID=your-shopify-client-id
CLIENT_SECRET=your-shopify-client-secret

# Numeric Shop ID (found in Shopify Admin URL or IdP settings)
SHOP_ID=12345678

# Your myshopify subdomain (e.g. dipanshi-dynamic-dreamz)
SHOP_DOMAIN=your-shop-name

# ─── MSG91 ────────────────────────────────────────────────────────────────────
# From MSG91 Dashboard → Profile → API Keys
MSG91_AUTH_KEY=your-msg91-auth-key

# From MSG91 → OTP Widget → Widget Settings → Widget ID
MSG91_WIDGET_ID=your-widget-id

# From MSG91 → SendOTP → Templates → your SMS template ID
MSG91_TEMPLATE_ID=your-template-id

# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED: Any long random string — used to sign OIDC session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If this is missing or changes, all active sessions will break!
COOKIE_SECRET=shopify-otp-super-secret-cookie-key-min-32-chars

