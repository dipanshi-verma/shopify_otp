<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Enter OTP</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f6f6f7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.08);
      padding: 40px 36px;
      width: 100%;
      max-width: 420px;
    }
    .logo {
      text-align: center;
      margin-bottom: 28px;
    }
    .logo h1 { font-size: 22px; font-weight: 600; color: #1a1a1a; }
    .logo p { font-size: 14px; color: #6b7280; margin-top: 6px; }
    .logo strong { color: #1a1a1a; }
    label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      color: #374151;
      margin-bottom: 6px;
    }
    .otp-input {
      width: 100%;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      padding: 13px 14px;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 10px;
      text-align: center;
      outline: none;
      transition: border-color 0.2s;
      color: #1a1a1a;
    }
    .otp-input:focus {
      border-color: #5c6ac4;
      box-shadow: 0 0 0 3px rgba(92,106,196,0.15);
    }
    .error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 16px;
    }
    button[type="submit"] {
      width: 100%;
      background: #5c6ac4;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 13px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 18px;
      transition: background 0.2s;
    }
    button[type="submit"]:hover { background: #4959b8; }
    .resend-wrap {
      text-align: center;
      margin-top: 18px;
    }
    .resend-wrap a {
      font-size: 13px;
      color: #5c6ac4;
      text-decoration: none;
      font-weight: 500;
    }
    .resend-wrap a:hover { text-decoration: underline; }
    .back {
      display: block;
      text-align: center;
      font-size: 13px;
      color: #9ca3af;
      margin-top: 12px;
      text-decoration: none;
    }
    .back:hover { color: #6b7280; }
    #timer { font-size: 12px; color: #9ca3af; margin-top: 8px; text-align: center; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <h1>Enter OTP</h1>
      <p>Sent to <strong>+91 <%= phone %></strong></p>
    </div>

   <% if (typeof demoOtp !== 'undefined' && demoOtp) { %>
      <div style="background:#fffbeb;border:1px solid #fcd34d;color:#92400e;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:16px;text-align:center;">
        Demo mode &mdash; OTP is: <strong><%= demoOtp %></strong>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/interaction/<%= uid %>/verify-otp">
      <input type="hidden" name="phone" value="<%= phone %>"/>
      <input type="hidden" name="reqId" value="<%= typeof reqId !== 'undefined' ? reqId || '' : '' %>"/>
      <label for="otp">One-time password</label>
      <input
        type="text"
        inputmode="numeric"
        pattern="\d{4,6}"
        id="otp"
        name="otp"
        class="otp-input"
        placeholder="••••••"
        value="<%= demoOtp || '' %>"
        maxlength="6"
        required
        autofocus
      />
      <button type="submit">Verify & Sign in</button>
    </form>

    <div id="timer">Resend available in <span id="countdown">30</span>s</div>

    <div class="resend-wrap" id="resend-wrap" style="display:none">
      <a href="/interaction/<%= uid %>">Resend OTP</a>
    </div>

    <a class="back" href="/interaction/<%= uid %>">← Change number</a>
  </div>

  <script>
    let seconds = 30;
    const countdownEl = document.getElementById('countdown');
    const timerEl = document.getElementById('timer');
    const resendEl = document.getElementById('resend-wrap');

    const interval = setInterval(() => {
      seconds--;
      countdownEl.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(interval);
        timerEl.style.display = 'none';
        resendEl.style.display = 'block';
      }
    }, 1000);
  </script>
</body>
</html>
